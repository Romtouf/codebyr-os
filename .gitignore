# Images ISO et artefacts de build (trop lourds pour git — voir Releases)
dist/
*.iso
*.iso.sha256

# Arbres de build live-build (générés)
.build/
cache/
chroot/
binary/

# Dépôt APT généré (voir packaging/publish-apt.sh) et paquets construits
apt-repo/
*.deb

# Clés PRIVÉES et trousseaux binaires — ne JAMAIS committer.
# (La clé PUBLIQUE codebyr-signing-key.asc, elle, est suivie : voir plus bas.)
*-SECRETE.asc
*secret*.asc
*.gpg

# Divers
*.log
*.tmp

# Caches Python (tests de compilation)
__pycache__/
*.pyc
