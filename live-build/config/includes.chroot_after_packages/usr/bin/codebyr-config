#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
codebyr-config — Configuration de Codebyr OS.
Permet à chacun de définir SES vrais sites bancaires (protégés + surveillés par
le bouclier anti-hameçonnage) et de voir ses Espaces. 100% local.
"""
import configparser
import glob
import json
import os
import re
import shutil
import subprocess

import gi
gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
from gi.repository import Adw, Gtk, Gio, GLib  # noqa: E402

SYSTEM = "/etc/codebyr/espaces.json"
USER = os.path.expanduser("~/.config/codebyr/espaces.json")


def load_registry():
    path = USER if os.path.exists(USER) else SYSTEM
    try:
        with open(path, encoding="utf-8") as f:
            return json.load(f)
    except (OSError, ValueError):
        return {"espaces": [], "apps": []}


def save_registry(data):
    os.makedirs(os.path.dirname(USER), exist_ok=True)
    with open(USER, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)


def espace_banque(data):
    """Renvoie l'Espace à réseau restreint (Banque), ou None."""
    for e in data.get("espaces", []):
        r = e.get("reseau") or {}
        if r.get("mode") == "liste-blanche":
            return e
    # sinon, on prend « banque » et on lui crée une liste blanche vide
    for e in data.get("espaces", []):
        if e.get("id") == "banque":
            e["reseau"] = {"mode": "liste-blanche", "domaines": []}
            return e
    return None


def capacites_machine():
    """Capacités d'isolation réelles de cette machine (pour info honnête)."""
    def user_ns():
        try:
            with open("/proc/sys/kernel/unprivileged_userns_clone") as f:
                return f.read().strip() == "1"
        except OSError:
            return True
    kvm = os.path.exists("/dev/kvm") and os.access("/dev/kvm", os.R_OK | os.W_OK)
    return [
        ("Bac à sable (bubblewrap)", bool(shutil.which("bwrap"))),
        ("Isolation utilisateur", user_ns()),
        ("Plafonds mémoire / processus", bool(shutil.which("systemd-run"))),
        ("Accélération matérielle KVM", kvm),
    ]


def apps_installees():
    """Détecte les applications installées via leurs fichiers .desktop
    (système, utilisateur, Flatpak). Renvoie une liste triée de (nom, commande),
    codes de champ (%U, %f…) retirés, sans doublons ni entrées cachées."""
    dossiers = [
        "/usr/share/applications",
        "/var/lib/flatpak/exports/share/applications",
        os.path.expanduser("~/.local/share/applications"),
        os.path.expanduser("~/.local/share/flatpak/exports/share/applications"),
    ]
    vus = {}
    for d in dossiers:
        est_flatpak = "flatpak" in d
        for f in sorted(glob.glob(os.path.join(d, "*.desktop"))):
            cp = configparser.RawConfigParser(interpolation=None, strict=False)
            try:
                cp.read(f, encoding="utf-8")
            except (OSError, configparser.Error):
                continue
            if not cp.has_section("Desktop Entry"):
                continue
            de = cp["Desktop Entry"]
            if (de.get("Type") != "Application"
                    or de.get("NoDisplay", "false").lower() == "true"
                    or de.get("Hidden", "false").lower() == "true"):
                continue
            base = os.path.basename(f)
            if base.lower().startswith(("io.codebyr.", "codebyr")):
                continue  # nos propres lanceurs internes
            nom = de.get("Name[fr]") or de.get("Name")
            exe = de.get("Exec", "")
            if not nom or not exe:
                continue
            if est_flatpak:
                # Commande propre et fiable pour un Flatpak : « flatpak run <ID> »
                # (l'ID = nom du .desktop). Évite les jetons @@ de la ligne Exec.
                app_id = base[:-len(".desktop")]
                cmd = "flatpak run " + app_id
            else:
                cmd = re.sub(r"%[fFuUdDnNickvm]", "", exe)
                cmd = re.sub(r"\s+", " ", cmd).strip()
            if cmd and nom not in vus:
                vus[nom] = cmd
    return sorted(vus.items(), key=lambda x: x[0].lower())


class Fenetre(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title="Configuration Codebyr")
        self.set_default_size(720, 640)
        self._data = load_registry()
        self._scope_idx = 0  # 0 = liste commune ; 1..N = un Espace

        self._page = Adw.PreferencesPage()
        self._construire()

        tv = Adw.ToolbarView()
        header = Adw.HeaderBar()
        header.set_title_widget(Adw.WindowTitle(title="Configuration Codebyr",
                                                subtitle="Codebyr OS"))
        tv.add_top_bar(header)
        tv.set_content(self._page)
        self._toaster = Adw.ToastOverlay()
        self._toaster.set_child(tv)
        self.set_content(self._toaster)

        # Recharge le registre quand la fenêtre reprend le focus : une
        # installation lancée en terminal aura modifié le fichier.
        self._registre_mtime = self._mtime_registre()
        self.connect("notify::is-active", self._peut_etre_recharger)

    def _mtime_registre(self):
        try:
            return os.path.getmtime(USER if os.path.exists(USER) else SYSTEM)
        except OSError:
            return 0

    def _peut_etre_recharger(self, *_a):
        if not self.is_active():
            return
        m = self._mtime_registre()
        if m != self._registre_mtime:
            self._registre_mtime = m
            self._data = load_registry()
            self._construire()

    # ---- Reconstruit toute la page (après modification) ----
    def _construire(self):
        # vider la page
        child = self._page.get_first_child()
        # PreferencesPage n'expose pas remove aisément : on recrée les groupes.
        for g in list(getattr(self, "_groupes", [])):
            self._page.remove(g)
        self._groupes = []

        banque = espace_banque(self._data)

        intro = Adw.PreferencesGroup(
            title="Le bouclier anti-hameçonnage",
            description="Codebyr n'autorise QUE ces sites dans l'Espace Banque, et "
                        "vous alerte si un autre site tente de les imiter. Ajoutez "
                        "ici les adresses de VOTRE banque.")
        self._page.add(intro)
        self._groupes.append(intro)

        grp = Adw.PreferencesGroup(title="Sites de votre banque")
        self._page.add(grp)
        self._groupes.append(grp)

        domaines = (banque.get("reseau", {}).get("domaines", []) if banque else [])
        if not domaines:
            vide = Adw.ActionRow(title="Aucun site pour l'instant",
                                 subtitle="Ajoutez le site de votre banque ci-dessous.")
            grp.add(vide)
        for d in domaines:
            row = Adw.ActionRow(title=d)
            btn = Gtk.Button(icon_name="user-trash-symbolic", valign=Gtk.Align.CENTER)
            btn.add_css_class("flat")
            btn.connect("clicked", self._supprimer_domaine, d)
            row.add_suffix(btn)
            grp.add(row)

        ajout = Adw.EntryRow(title="Ajouter un site (ex. mabanque.fr)")
        badd = Gtk.Button(icon_name="list-add-symbolic", valign=Gtk.Align.CENTER)
        badd.add_css_class("flat")
        badd.connect("clicked", lambda _b: self._ajouter_domaine(ajout.get_text()))
        ajout.add_suffix(badd)
        ajout.connect("entry-activated", lambda _r: self._ajouter_domaine(ajout.get_text()))
        grp.add(ajout)

        # Espaces + blindage
        gesp = Adw.PreferencesGroup(
            title="Vos Espaces et leur blindage",
            description="Le Blindage renforce l'isolation d'un Espace : bac à sable "
                        "utilisateur, zéro privilège, session neuve. Idéal pour la Banque.")
        self._page.add(gesp)
        self._groupes.append(gesp)
        for e in self._data.get("espaces", []):
            tag = "  (éphémère)" if e.get("ephemere") else ""
            row = Adw.SwitchRow(title=e.get("nom", e.get("id")) + tag,
                                subtitle=e.get("couleur", ""))
            row.set_active(e.get("blindage") == "renforce")
            pastille = Gtk.Box()
            pastille.set_size_request(18, 18)
            pastille.set_valign(Gtk.Align.CENTER)
            css = Gtk.CssProvider()
            css.load_from_data(
                ("box{background:%s;border-radius:9px;}" % e.get("couleur", "#888")).encode())
            pastille.get_style_context().add_provider(css, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
            row.add_prefix(pastille)
            row.connect("notify::active", self._basculer_blindage, e.get("id"))
            gesp.add(row)

        # Capacités réelles de la machine (transparence)
        gcap = Adw.PreferencesGroup(
            title="Isolation disponible sur cette machine",
            description="Codebyr s'adapte au matériel. Le Jetable d'une pièce jointe "
                        "s'ouvre toujours blindé ET sans réseau.")
        self._page.add(gcap)
        self._groupes.append(gcap)
        for nom, dispo in capacites_machine():
            r = Adw.ActionRow(title=nom)
            ic = Gtk.Image.new_from_icon_name(
                "emblem-ok-symbolic" if dispo else "window-close-symbolic")
            ic.add_css_class("success" if dispo else "dim-label")
            r.add_suffix(ic)
            gcap.add(r)

        self._groupe_applications()

    # ---- Section « Applications du menu » (par Espace ou commune) ----
    def _espaces_registre(self):
        return self._data.get("espaces", [])

    def _espace_scope(self):
        """Espace sélectionné (scope_idx 1..N), ou None pour la liste commune."""
        if self._scope_idx <= 0:
            return None
        espaces = self._espaces_registre()
        i = self._scope_idx - 1
        return espaces[i] if 0 <= i < len(espaces) else None

    def _apps_effectives(self):
        """(liste, personnalisé) pour la portée courante. Un Espace sans liste
        propre hérite de la liste commune (personnalisé = False)."""
        esp = self._espace_scope()
        if esp is None:
            return self._data.setdefault("apps", []), True
        if isinstance(esp.get("apps"), list):
            return esp["apps"], True
        return self._data.get("apps", []), False

    def _liste_modifiable(self):
        """Retourne la liste à modifier, en la matérialisant si un Espace héritait."""
        esp = self._espace_scope()
        if esp is None:
            return self._data.setdefault("apps", [])
        if not isinstance(esp.get("apps"), list):
            esp["apps"] = [dict(a) for a in self._data.get("apps", [])]
        return esp["apps"]

    def _groupe_applications(self):
        esp = self._espace_scope()
        titre_scope = "la liste commune" if esp is None else "« %s »" % esp.get("nom", "")
        grp = Adw.PreferencesGroup(
            title="Applications du menu",
            description="Ce qui apparaît dans le menu du Sceau. Choisissez la portée : "
                        "la liste commune (tous les Espaces) ou un Espace précis.")
        self._page.add(grp)
        self._groupes.append(grp)

        # Sélecteur de portée
        noms = ["Tous les Espaces (liste commune)"] + \
               [e.get("nom", e.get("id")) for e in self._espaces_registre()]
        modele = Gtk.StringList.new(noms)
        combo = Adw.ComboRow(title="Configurer les applications de")
        combo.set_model(modele)
        combo.set_selected(min(self._scope_idx, len(noms) - 1))
        combo.connect("notify::selected", self._scope_change)
        grp.add(combo)

        apps, perso = self._apps_effectives()
        if esp is not None and not perso:
            info = Adw.ActionRow(
                title="Cet Espace utilise la liste commune",
                subtitle="Ajoutez ou retirez une application pour la personnaliser.")
            info.add_css_class("dim-label")
            grp.add(info)

        for app in apps:
            row = Adw.ActionRow(title=app.get("nom", ""), subtitle=app.get("cmd", ""))
            btn = Gtk.Button(icon_name="user-trash-symbolic", valign=Gtk.Align.CENTER)
            btn.add_css_class("flat")
            btn.connect("clicked", self._supprimer_app, app.get("cmd", ""))
            row.add_suffix(btn)
            grp.add(row)

        ajout = Adw.ActionRow(
            title="Ajouter une application déjà installée",
            subtitle="Vers %s" % titre_scope)
        badd = Gtk.Button(icon_name="list-add-symbolic", valign=Gtk.Align.CENTER,
                          label="Choisir…")
        badd.add_css_class("suggested-action")
        badd.connect("clicked", lambda _b: self._ouvrir_selecteur_app())
        ajout.add_suffix(badd)
        grp.add(ajout)

        # Installation d'une NOUVELLE application, dédiée à un Espace précis
        # (isolée dans cet Espace). Sans objet pour la liste commune.
        if esp is not None and shutil.which("flatpak"):
            inst = Adw.ActionRow(
                title="Installer une nouvelle application dans « %s »" % esp.get("nom", ""),
                subtitle="Depuis Flathub — installée et isolée dans cet Espace uniquement")
            binst = Gtk.Button(icon_name="folder-download-symbolic",
                               valign=Gtk.Align.CENTER, label="Installer…")
            binst.connect("clicked", lambda _b, e=esp: self._ouvrir_installeur_flathub(e))
            inst.add_suffix(binst)
            grp.add(inst)

        # Ajout d'un programme LOCAL téléchargé (binaire, AppImage…) au menu.
        if esp is not None:
            prog = Adw.ActionRow(
                title="Ajouter un programme téléchargé",
                subtitle="Un fichier exécutable présent sur le disque, vers « %s »"
                         % esp.get("nom", ""))
            bprog = Gtk.Button(icon_name="document-open-symbolic",
                               valign=Gtk.Align.CENTER, label="Parcourir…")
            bprog.connect("clicked", lambda _b, e=esp: self._ouvrir_ajout_programme(e))
            prog.add_suffix(bprog)
            grp.add(prog)

    def _scope_change(self, combo, _pspec):
        self._scope_idx = combo.get_selected()
        self._construire()

    def _supprimer_app(self, _btn, cmd):
        esp = self._espace_scope()
        # App Flatpak installée DANS cet Espace → on la désinstalle vraiment.
        if (esp is not None and cmd.startswith("flatpak run ")
                and shutil.which("flatpak")):
            appid = cmd.split()[-1]
            d = os.path.expanduser(
                "~/.local/share/codebyr/espaces/%s/flatpak/app/%s" % (esp.get("id"), appid))
            if os.path.isdir(d):
                term_cmd = ("codebyr-space remove-app %s %s; echo; "
                            "echo '— Terminé. Fermez cette fenêtre. —'; read _"
                            % (esp.get("id"), appid))
                for term in ("kgx", "gnome-terminal", "xterm"):
                    if shutil.which(term):
                        try:
                            subprocess.Popen([term, "--", "sh", "-c", term_cmd])
                        except OSError:
                            continue
                        break
                return  # le rechargement au focus rafraîchira la liste
        lst = self._liste_modifiable()
        lst[:] = [a for a in lst if a.get("cmd") != cmd]
        save_registry(self._data)
        self._construire()

    def _ajouter_app(self, nom, cmd):
        lst = self._liste_modifiable()
        if not any(a.get("cmd") == cmd for a in lst):
            lst.append({"nom": nom, "cmd": cmd})
            save_registry(self._data)
        self._construire()

    def _ouvrir_selecteur_app(self):
        dlg = Adw.Window(transient_for=self, modal=True,
                         default_width=460, default_height=560, title="Ajouter une application")
        tv = Adw.ToolbarView()
        tv.add_top_bar(Adw.HeaderBar())
        boite = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        boite.set_margin_top(6); boite.set_margin_bottom(6)
        boite.set_margin_start(6); boite.set_margin_end(6)
        recherche = Gtk.SearchEntry(placeholder_text="Rechercher une application…")
        boite.append(recherche)
        defilement = Gtk.ScrolledWindow(vexpand=True)
        liste = Gtk.ListBox()
        liste.add_css_class("boxed-list")
        liste.set_selection_mode(Gtk.SelectionMode.NONE)
        defilement.set_child(liste)
        boite.append(defilement)
        tv.set_content(boite)
        dlg.set_content(tv)

        toutes = apps_installees()

        def peupler(filtre=""):
            child = liste.get_first_child()
            while child is not None:
                nxt = child.get_next_sibling()
                liste.remove(child)
                child = nxt
            f = filtre.strip().lower()
            for nom, cmd in toutes:
                if f and f not in nom.lower():
                    continue
                row = Adw.ActionRow(title=nom, subtitle=cmd, activatable=True)
                row.connect("activated", self._app_choisie, nom, cmd, dlg)
                liste.append(row)

        recherche.connect("search-changed", lambda e: peupler(e.get_text()))
        peupler()
        dlg.present()

    def _app_choisie(self, _row, nom, cmd, dlg):
        dlg.close()
        self._ajouter_app(nom, cmd)

    # ---- Installation d'une nouvelle app Flathub dans un Espace ----
    def _ouvrir_installeur_flathub(self, esp):
        dlg = Adw.Window(transient_for=self, modal=True, default_width=500,
                         default_height=600,
                         title="Installer dans « %s »" % esp.get("nom", ""))
        tv = Adw.ToolbarView()
        tv.add_top_bar(Adw.HeaderBar())
        boite = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        for m in ("top", "bottom", "start", "end"):
            getattr(boite, "set_margin_" + m)(8)
        recherche = Gtk.SearchEntry(
            placeholder_text="Rechercher sur Flathub (ex. brave, gimp, vlc)…")
        boite.append(recherche)
        etat = Gtk.Label(label="Tapez le nom d'une application, puis Entrée.",
                         wrap=True, xalign=0)
        etat.add_css_class("dim-label")
        boite.append(etat)
        defilement = Gtk.ScrolledWindow(vexpand=True)
        liste = Gtk.ListBox()
        liste.add_css_class("boxed-list")
        liste.set_selection_mode(Gtk.SelectionMode.NONE)
        defilement.set_child(liste)
        boite.append(defilement)
        tv.set_content(boite)
        dlg.set_content(tv)

        def vider():
            child = liste.get_first_child()
            while child is not None:
                nxt = child.get_next_sibling()
                liste.remove(child)
                child = nxt

        def rechercher(_e):
            terme = recherche.get_text().strip()
            vider()
            if len(terme) < 2:
                return
            etat.set_text("Recherche…")
            resultats = self._flathub_search(terme)
            if not resultats:
                etat.set_text("Aucun résultat (ou catalogue pas encore chargé).")
                return
            etat.set_text("%d résultat(s) — cliquez pour installer :" % len(resultats))
            for appid, nom, desc in resultats:
                row = Adw.ActionRow(title=nom, subtitle=desc or appid, activatable=True)
                row.connect("activated", self._installer_flathub, esp, appid, nom, dlg)
                liste.append(row)

        recherche.connect("activate", rechercher)
        recherche.connect("search-changed",
                          lambda e: rechercher(e) if len(e.get_text()) >= 3 else None)
        dlg.present()

    def _flathub_search(self, terme):
        """Recherche Flathub via l'outil flatpak. Renvoie [(appid, nom, desc)]."""
        try:
            out = subprocess.run(
                ["flatpak", "search", "--columns=application,name,description", terme],
                capture_output=True, text=True, timeout=25).stdout
        except (OSError, subprocess.SubprocessError):
            return []
        res = []
        for line in out.splitlines():
            parts = line.split("\t")
            if len(parts) >= 2 and "." in parts[0]:
                appid = parts[0].strip()
                nom = parts[1].strip() or appid
                desc = parts[2].strip() if len(parts) >= 3 else ""
                res.append((appid, nom, desc))
        return res[:40]

    def _installer_flathub(self, _row, esp, appid, nom, dlg):
        """Lance l'installation dans un terminal (progression visible)."""
        dlg.close()
        cmd = ("codebyr-space install %s %s; echo; "
               "echo '— Terminé. Fermez cette fenêtre. —'; "
               "read _" % (esp.get("id"), appid))
        lance = False
        for term in ("kgx", "gnome-terminal", "xterm"):
            if shutil.which(term):
                try:
                    subprocess.Popen([term, "--", "sh", "-c", cmd])
                    lance = True
                    break
                except OSError:
                    continue
        toast = Adw.Toast(title=("Installation de « %s » lancée dans l'Espace %s…"
                                 % (nom, esp.get("nom", "")))
                          if lance else "Impossible d'ouvrir un terminal.")
        if hasattr(self, "_toaster"):
            self._toaster.add_toast(toast)

    # ---- Ajout d'un programme LOCAL (binaire téléchargé) au menu d'un Espace ----
    def _ouvrir_ajout_programme(self, esp):
        dialog = Gtk.FileDialog(title="Choisir un programme")
        dl = os.path.expanduser(
            "~/.local/share/codebyr/espaces/%s/home/Téléchargements" % esp.get("id"))
        if os.path.isdir(dl):
            dialog.set_initial_folder(Gio.File.new_for_path(dl))
        dialog.open(self, None, self._programme_choisi, esp)

    def _programme_choisi(self, dialog, result, esp):
        try:
            fichier = dialog.open_finish(result)
        except GLib.Error:
            return
        if fichier is None:
            return
        self._dialogue_nom_programme(esp, fichier.get_path())

    def _dialogue_nom_programme(self, esp, chemin):
        dlg = Adw.Window(transient_for=self, modal=True, default_width=440,
                         title="Ajouter au menu")
        tv = Adw.ToolbarView()
        tv.add_top_bar(Adw.HeaderBar())
        page = Adw.PreferencesPage()
        grp = Adw.PreferencesGroup(
            title="Ajouter « %s »" % os.path.basename(chemin),
            description="Ce programme apparaîtra dans le menu du Sceau de l'Espace "
                        "« %s »." % esp.get("nom", ""))
        nom_row = Adw.EntryRow(title="Nom affiché")
        nom_row.set_text(os.path.splitext(os.path.basename(chemin))[0].capitalize())
        grp.add(nom_row)
        sw = Adw.SwitchRow(
            title="Application Electron / Chromium",
            subtitle="Ajoute « --no-sandbox » (VS Code, Antigravity, navigateurs…)")
        grp.add(sw)
        page.add(grp)

        bar = Gtk.Box(halign=Gtk.Align.END, spacing=8)
        for m in ("top", "bottom", "start", "end"):
            getattr(bar, "set_margin_" + m)(12)
        annuler = Gtk.Button(label="Annuler")
        annuler.connect("clicked", lambda _b: dlg.close())
        ajouter = Gtk.Button(label="Ajouter au menu")
        ajouter.add_css_class("suggested-action")
        ajouter.connect("clicked", lambda _b: self._ajouter_programme(
            esp, chemin, nom_row.get_text(), sw.get_active(), dlg))
        bar.append(annuler)
        bar.append(ajouter)

        boite = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        boite.append(page)
        boite.append(bar)
        tv.set_content(boite)
        dlg.set_content(tv)
        dlg.present()

    def _ajouter_programme(self, esp, chemin, nom, nosandbox, dlg):
        dlg.close()
        nom = (nom or os.path.basename(chemin)).strip()
        args = ["codebyr-space", "add-app", esp.get("id"), nom, chemin]
        if nosandbox:
            args.append("--no-sandbox")
        ok = True
        try:
            subprocess.run(args, timeout=30, check=True)
        except (OSError, subprocess.SubprocessError):
            ok = False
        self._data = load_registry()
        self._registre_mtime = self._mtime_registre()
        self._construire()
        if hasattr(self, "_toaster"):
            self._toaster.add_toast(Adw.Toast(
                title=("« %s » ajouté au menu de %s" % (nom, esp.get("nom", "")))
                if ok else "Impossible d'ajouter ce programme."))

    def _ajouter_domaine(self, texte):
        # removeprefix, PAS lstrip("www.") : lstrip retire tout caractère de
        # tête de l'ensemble {w, .}, donc « wise.com » deviendrait « ise.com ».
        d = (texte or "").strip().lower()
        if d.startswith("http://"):
            d = d[7:]
        elif d.startswith("https://"):
            d = d[8:]
        d = d.split("/", 1)[0].removeprefix("www.")
        if not d or "." not in d:
            return
        banque = espace_banque(self._data)
        if banque is None:
            return
        banque.setdefault("reseau", {"mode": "liste-blanche", "domaines": []})
        doms = banque["reseau"].setdefault("domaines", [])
        # on ajoute aussi le motif *.domaine pour couvrir les sous-domaines
        for cible in (d, "*." + d):
            if cible not in doms:
                doms.append(cible)
        save_registry(self._data)
        self._construire()

    def _basculer_blindage(self, row, _pspec, esp_id):
        for e in self._data.get("espaces", []):
            if e.get("id") == esp_id:
                if row.get_active():
                    e["blindage"] = "renforce"
                else:
                    e.pop("blindage", None)
                break
        save_registry(self._data)

    def _supprimer_domaine(self, _btn, d):
        banque = espace_banque(self._data)
        if banque is None:
            return
        doms = banque.get("reseau", {}).get("domaines", [])
        banque["reseau"]["domaines"] = [x for x in doms if x != d]
        save_registry(self._data)
        self._construire()


class Config(Adw.Application):
    def __init__(self):
        super().__init__(application_id="io.codebyr.Config",
                         flags=Gio.ApplicationFlags.FLAGS_NONE)

    def do_activate(self):
        win = self.props.active_window or Fenetre(self)
        win.present()


if __name__ == "__main__":
    Config().run(None)
