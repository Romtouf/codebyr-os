#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
codebyr-jetable — ouvre un lien OU un fichier dans un Espace Jetable éphémère.

Deux niveaux, selon la cible :
  - FICHIER (pièce jointe) : bulle blindée ET sans réseau (le piège ne peut
    ni téléphoner dehors, ni rien laisser derrière lui) ;
  - LIEN : bulle blindée qui s'autodétruit — le réseau reste ouvert, il est
    nécessaire pour charger la page. La protection est l'isolation et
    l'éphémère, pas la coupure réseau.

Usage :
  codebyr-jetable <url>
  codebyr-jetable <fichier>
"""
import os
import sys
import subprocess


def main(argv):
    if len(argv) < 2 or argv[1] in ("-h", "--help"):
        print(__doc__)
        return 0 if len(argv) >= 2 else 2

    cible = argv[1].strip()

    # Fichier local (pièce jointe) : on l'ouvre isolé, via une copie dans l'Espace.
    if cible.startswith("file://"):
        cible = cible[7:]
    if os.path.isfile(cible):
        cmd = ["codebyr-space", "launch", "jetable", "--fichier", cible]
        return subprocess.call(cmd)

    # Sinon : un lien web.
    if not cible.startswith(("http://", "https://")):
        cible = "https://" + cible
    cmd = ["codebyr-space", "launch", "jetable", "--", "firefox-esr", cible]
    return subprocess.call(cmd)


if __name__ == "__main__":
    sys.exit(main(sys.argv))
