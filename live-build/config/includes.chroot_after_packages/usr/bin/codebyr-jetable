#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
codebyr-jetable — ouvre un lien OU un fichier dans un Espace Jetable éphémère.

Un lien ou une pièce jointe douteux s'ouvrent dans une bulle isolée qui
s'autodétruit à la fermeture : le piège explose dans le vide, sans toucher
à tes données.

Usage :
  codebyr-jetable <url>
  codebyr-jetable <fichier>
"""
import os
import sys
import subprocess


def main(argv):
    if len(argv) < 2 or argv[1] in ("-h", "--help"):
        print(__doc__)
        return 0 if len(argv) >= 2 else 2

    cible = argv[1].strip()

    # Fichier local (pièce jointe) : on l'ouvre isolé, via une copie dans l'Espace.
    if cible.startswith("file://"):
        cible = cible[7:]
    if os.path.isfile(cible):
        cmd = ["codebyr-space", "launch", "jetable", "--fichier", cible]
        return subprocess.call(cmd)

    # Sinon : un lien web.
    if not cible.startswith(("http://", "https://")):
        cible = "https://" + cible
    cmd = ["codebyr-space", "launch", "jetable", "--", "firefox-esr", cible]
    return subprocess.call(cmd)


if __name__ == "__main__":
    sys.exit(main(sys.argv))
